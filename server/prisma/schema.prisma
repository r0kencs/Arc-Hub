// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Map {
  id      String    @id
  name    String    @unique
  lineups Lineup[]
  spawns  Spawn[]
}

model UtilityType {
  id        String    @id
  name      String    @unique
  lineups   Lineup[]
}
model ThrowTechnique {
  id      String    @id
  name    String    @unique
  lineups Lineup[]  @relation("LineupTechniques")
}

enum MouseClick {
  LEFT
  RIGHT
  BOTH
}

model Side {
  id      String   @id
  lineups Lineup[] @relation("LineupSides")
  spawns  Spawn[]
}

model Lineup {
  id            String            @id @default(cuid())

  name          String

  map           Map               @relation(fields: [mapId], references: [id])
  mapId         String

  sides         Side[]            @relation("LineupSides")

  type          UtilityType       @relation(fields: [typeId], references: [id])
  typeId        String

  techniques    ThrowTechnique[]  @relation("LineupTechniques")

  mouseClick    MouseClick        @default(LEFT)

  x             Float
  y             Float
  z             Float
  pitch         Float
  yaw           Float

  @@index([mapId, typeId])
}

model Spawn {
  id    String    @id @default(cuid())
  name  String // e.g., "Spawn 1", "Best AWP Spawn"
  
  // Relations
  map   Map    @relation(fields: [mapId], references: [id])
  mapId String
  
  side  Side   @relation(fields: [sideId], references: [id])
  sideId String

  // Coordinates for the spawn point
  x     Float
  y     Float
  z     Float

  @@unique([mapId, name]) // Prevents duplicate naming on the same map

  @@index([mapId, sideId]) // Optimized for "Get all T spawns for Mirage"
}