// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Map {
  id      String    @id
  name    String    @unique
  lineups Lineup[]
}

model UtilityType {
  id        String    @id
  name      String    @unique
  lineups   Lineup[]
}
model ThrowTechnique {
  id      String    @id
  name    String    @unique
  lineups Lineup[]  @relation("LineupTechniques")
}

enum MouseClick {
  LEFT
  RIGHT
  BOTH
}
model Lineup {
  id            String            @id @default(cuid())

  map           Map               @relation(fields: [mapId], references: [id])
  mapId         String

  type          UtilityType       @relation(fields: [typeId], references: [id])
  typeId        String

  techniques    ThrowTechnique[]  @relation("LineupTechniques")

  mouseClick    MouseClick        @default(LEFT)

  x             Float
  y             Float
  z             Float
  pitch         Float
  yaw           Float
}